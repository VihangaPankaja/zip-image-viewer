{
  "name": "zip-image-viewer",
  "version": "1.3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "start": "node build/server/index.js"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^19.6.0",
    "got": "^14.6.6",
    "hls.js": "^1.5.21",
    "lucide-react": "^1.7.0",
    "mime-types": "^3.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3",
    "video.js": "^8.23.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.3.4",
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^6.2.2",
    "vitest": "^2.1.9",
    "jsdom": "^25.0.1"
  }
}

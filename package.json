{
  "name": "zip-image-viewer",
  "version": "1.0.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "mime-types": "^3.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.22.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
